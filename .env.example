# DATABASE_URL — общая БД с sales-plan-dashboard.
# В Render возьми из сервиса maria-dashboard (или копию).
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# GROQ для LLM-аналитики (тот же ключ что в dashboard)
GROQ_API_KEY=

# Порт (Render задаст сам, локально по умолчанию 3001)
PORT=3001

# Для Telegram-отчётов
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
